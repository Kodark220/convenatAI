# ============================================================
# convenatAI Environment Configuration
# Copy this file to .env and fill in your real values.
# ============================================================

# --- Circle Developer-Controlled Wallets (Arc Network) ---
# Get these from: https://console.circle.com → Developer → API Keys
CIRCLE_API_KEY=TEST_API_KEY:9f7b169788f9f09e18e0aca494d74994:69ae28953a46c7fe754656228967030a
CIRCLE_ENTITY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Arc Testnet ---
# RPC endpoint for reading on-chain state
ARC_RPC_URL=https://rpc.testnet.arc.network

# USDC Token ID on Arc Testnet. Fetch from Circle Tokens API.
USDC_TOKEN_ID=7b2e8a15-0610-4c7b-83c0-394e24eb5181

# ERC-8183 AgenticCommerce contract (already deployed on Arc Testnet)
# Used for job creation, escrow, settlement
AGENTIC_COMMERCE_CONTRACT=0x0747EEf0706327138c69792bF28Cd525089e4583

# --- GenLayer (Bradbury Testnet) ---
# Get from: https://studio.genlayer.com → Settings → RPC
GENLAYER_RPC_URL=https://studio.genlayer.com:8443/api

# Your GenLayer private key (without 0x prefix)
GENLAYER_PRIVATE_KEY=

# Address of ConvenatContract.py once deployed to GenLayer Studio
# See contracts/DEPLOY_GENLAYER.md for deployment instructions
CONVENAT_CONTRACT_ADDRESS=

# --- LayerZero Bridge (from bridge-boilerplate) ---
# Fill in after deploying the bridge boilerplate smart contracts
BRIDGE_SENDER_ADDRESS=
BRIDGE_RECEIVER_IC_ADDRESS=
ZKSYNC_BRIDGE_FORWARDER_ADDRESS=
ZKSYNC_BRIDGE_RECEIVER_ADDRESS=
