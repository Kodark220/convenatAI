# ─── ConvenatAI Dashboard — Environment Variables ─────────────────────────────
# Copy this to .env.local and fill in values
# If NEXT_PUBLIC_API_URL is empty, the app runs with mock data (great for frontend dev)

# Your backend API base URL (leave empty to use mock data)
NEXT_PUBLIC_API_URL=

# WalletConnect Project ID — get a free one at https://cloud.walletconnect.com
# Required for wallet connect modal to work properly
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Contract addresses (filled in by backend team after deployment)
NEXT_PUBLIC_ARC_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GENLAYER_CONTRACT=0x0000000000000000000000000000000000000000

# Chain RPC endpoints (override defaults if you have dedicated nodes)
NEXT_PUBLIC_ARC_RPC=https://rpc.arc-testnet.io
NEXT_PUBLIC_GENLAYER_RPC=https://rpc.genlayer-testnet.io
